VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
VITE_SARMOK_DASHBOARD_API_URL=https://api.smktelkom-mlg.sch.id/auth/sarmok/dashboard
# Sementara dipakai sebagai auth terpusat saat build/deploy agar user tidak perlu set auth per browser.
# Untuk jangka panjang, pindahkan kredensial ini ke backend/proxy runtime agar tidak masuk bundle static.
VITE_SARMOK_BASIC_AUTH_USERNAME=YOUR_SARMOK_BASIC_AUTH_USERNAME
VITE_SARMOK_BASIC_AUTH_PASSWORD=YOUR_SARMOK_BASIC_AUTH_PASSWORD
